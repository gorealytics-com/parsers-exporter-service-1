{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "tags": ["aragog", "writers"],
  "title": "Aragog Writers Overview",
  "uid": "aragog-writers",
  "templating": {
    "list": [
      {
        "name": "writer",
        "type": "custom",
        "current": {"text": "All", "value": "$__all"},
        "options": [
          {"text": "All", "value": "$__all"},
          {"text": "pg", "value": "pg"},
          {"text": "ch", "value": "ch"}
        ],
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "title": "Records Written/sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(aragog_writer_records_written_total{writer=~\"$writer\"}[5m])) by (writer, schema)", "legendFormat": "{{writer}}/{{schema}}"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Write Errors/sec",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "sum(rate(aragog_writer_errors_total{writer=~\"$writer\"}[5m])) by (writer, schema)", "legendFormat": "{{writer}}/{{schema}}"}],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    },
    {
      "title": "Batch Write Duration p50/p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum(rate(aragog_writer_batch_write_seconds_bucket{writer=~\"$writer\"}[5m])) by (le, writer))", "legendFormat": "p50 {{writer}}"},
        {"expr": "histogram_quantile(0.95, sum(rate(aragog_writer_batch_write_seconds_bucket{writer=~\"$writer\"}[5m])) by (le, writer))", "legendFormat": "p95 {{writer}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "title": "Buffer Size (records in memory)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "aragog_writer_buffer_size{writer=~\"$writer\"}", "legendFormat": "{{writer}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"tooltip": {"mode": "multi"}}
    },
    {
      "title": "Total Written (24h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 0, "y": 16},
      "targets": [{"expr": "sum(increase(aragog_writer_records_written_total[24h])) by (writer)", "legendFormat": "{{writer}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "Write Errors (1h)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 16},
      "targets": [{"expr": "sum(increase(aragog_writer_errors_total[1h])) by (writer)", "legendFormat": "{{writer}}"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 1, "color": "red"}]}}}
    },
    {
      "title": "Active Writer Pods",
      "type": "stat",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 16},
      "targets": [{"expr": "count(up{job=~\".*writer.*\"} == 1)", "legendFormat": "pods"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    }
  ],
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s"
}
