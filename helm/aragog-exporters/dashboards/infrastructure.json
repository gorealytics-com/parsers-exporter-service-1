{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage per Pod",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"aragog.*\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "Memory Usage vs Limit (OOM Risk)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=~\"aragog.*\"}) by (pod)",
          "legendFormat": "used: {{pod}}"
        },
        {
          "expr": "sum(kube_pod_container_resource_limits{namespace=~\"aragog.*\", resource=\"memory\"}) by (pod)",
          "legendFormat": "limit: {{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Pod Restart Count",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "increase(kube_pod_container_status_restarts_total{namespace=~\"aragog.*\"}[1h])",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "title": "HPA Replicas: Current vs Desired",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=~\"aragog.*\"}",
          "legendFormat": "current: {{horizontalpodautoscaler}}"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_max_replicas{namespace=~\"aragog.*\"}",
          "legendFormat": "max: {{horizontalpodautoscaler}}"
        },
        {
          "expr": "kube_horizontalpodautoscaler_spec_min_replicas{namespace=~\"aragog.*\"}",
          "legendFormat": "min: {{horizontalpodautoscaler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "title": "PgBouncer Wait Queue",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "pgbouncer_show_pools_cl_waiting{namespace=~\"aragog.*\"}",
          "legendFormat": "{{database}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    }
  ],
  "schemaVersion": 39,
