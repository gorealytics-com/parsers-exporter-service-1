{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "tags": ["aragog", "infrastructure"],
  "title": "Aragog Infrastructure",
  "uid": "aragog-infra",
  "panels": [
    {
      "title": "Pod CPU Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum(rate(container_cpu_usage_seconds_total{namespace=~\"aragog.*\", container!=\"\"}[5m])) by (pod)", "legendFormat": "{{pod}}"}],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "title": "Pod Memory Usage",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "sum(container_memory_working_set_bytes{namespace=~\"aragog.*\", container!=\"\"}) by (pod)", "legendFormat": "{{pod}}"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "title": "Pod Restarts",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "increase(kube_pod_container_status_restarts_total{namespace=~\"aragog.*\"}[1h])", "legendFormat": "{{pod}}"}],
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 3, "color": "red"}]}}}
    },
    {
      "title": "HPA Current vs Desired Replicas",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=~\"aragog.*\"}", "legendFormat": "current {{horizontalpodautoscaler}}"},
        {"expr": "kube_horizontalpodautoscaler_status_desired_replicas{namespace=~\"aragog.*\"}", "legendFormat": "desired {{horizontalpodautoscaler}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "PgBouncer Active Connections",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [{"expr": "pgbouncer_show_pools_cl_active{namespace=~\"aragog.*\"}", "legendFormat": "active {{database}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "title": "PgBouncer Wait Queue",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [{"expr": "pgbouncer_show_pools_cl_waiting{namespace=~\"aragog.*\"}", "legendFormat": "waiting {{database}}"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 5, "color": "yellow"}, {"value": 20, "color": "red"}]}}}
    },
    {
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 24},
      "targets": [{"expr": "sum(kafka_consumergroup_lag_sum{consumergroup=~\"aragog.*\"}) by (consumergroup, topic)", "legendFormat": "{{consumergroup}} / {{topic}}"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"steps": [{"value": 0, "color": "green"}, {"value": 10000, "color": "yellow"}, {"value": 100000, "color": "red"}]}}}
    }
  ],
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s"
}
