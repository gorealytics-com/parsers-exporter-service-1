# =============================================================================
# aragog-exporters — Environment Variables Example
# =============================================================================
# These are injected by Vault Agent Injector in K8s.
# For local development, copy this to .env and fill in values.
# =============================================================================

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- PostgreSQL (via PgBouncer in K8s) ---
PG_URI=postgresql://user:password@localhost:5432/aragog

# --- ClickHouse ---
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# --- Telegram (transition period) ---
TELEGRAM_BOT_TOKEN=fake-token
TELEGRAM_CHAT_ID=fake-chat

# --- Slack ---
# Bot token for Alertmanager + CI notifications
# Store as GitHub Actions secret: SLACK_BOT_TOKEN
SLACK_BOT_TOKEN=faketoken

# --- Vault ---
# Vault UI: https://vault.rea:
# Secrets path: org/data/{env}/aragog_exporters

# --- Grafana ---
# Prod: https://grafana.
# Dev:  https://grafana.

# --- ArgoCD ---
# Prod: https://
# Dev:  https://

# --- Exporter identity (set per deployment in values.yaml) ---
EXPORTER_NAME=bing-map-search
EXPORTER_TYPE=organization
SOURCE_NAME="Bing Org Update"
SCHEMA=source_42
REDIS_QUEUE=bing_map_search:items
KAFKA_TOPIC=orgs.validated.v1
BATCH_SIZE=10000
LOG_LEVEL=INFO
