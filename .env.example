# =============================================================================
# aragog-exporters — Environment Variables
# =============================================================================
# These are injected by Vault Agent Injector in K8s.
# For local development, copy this file to .env and fill in values.
# =============================================================================

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (pg-writer connects via PgBouncer in K8s)
PG_URI=postgresql://user:password@localhost:5432/aragog_db

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Telegram notifications (legacy, transitioning to Slack)
TELEGRAM_BOT_TOKEN=fake-token
TELEGRAM_CHAT_ID=fake-chat-id

# Slack alerting
SLACK_BOT_TOKEN=xoxb-FAKE-TOKEN
e
# Logging
LOG_LEVEL=INFO

# =============================================================================
# Per-exporter vars (set by Helm, not .env)
# =============================================================================
# EXPORTER_NAME=bing_map_search
# EXPORTER_TYPE=map
# SOURCE_NAME=Bing Org Update
# SCHEMA=source_42
# REDIS_QUEUE=bing_map_search:items
# BATCH_SIZE=10000
# KAFKA_TOPIC=orgs.validated.v1
# CHECK_INTERVAL=30
# DUPEFILTER_KEY=  (reviews only)
