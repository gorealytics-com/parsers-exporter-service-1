{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/^version:.*/version: ${nextRelease.version}/' helm/aragog-exporters/Chart.yaml && sed -i 's/^appVersion:.*/appVersion: \"v${nextRelease.version}\"/' helm/aragog-exporters/Chart.yaml"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["helm/aragog-exporters/Chart.yaml"],
        "message": "chore(release): bump chart to v${nextRelease.version} [skip ci]"
      }
    ],
    "@semantic-release/github"
  ]
}
